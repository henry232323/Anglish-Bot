# Discord (required for deploy + slash command sync)
# Public key: Discord Developer Portal → Your app → General Information
DISCORD_PUBLIC_KEY=
# Bot token: Discord Developer Portal → Your app → Bot → Reset Token (used for register_commands.py)
DISCORD_BOT_TOKEN=

# Google Sheets wordbook (optional; only needed for /m, /f, /am, etc. lookup commands)
# Set GOOGLE_CREDENTIALS_JSON to the service account JSON. Use base64 to avoid newline/quote issues:
#   GOOGLE_CREDENTIALS_JSON=$(base64 -w 0 resources/client_secret.json)   # Linux
#   GOOGLE_CREDENTIALS_JSON=$(base64 < resources/client_secret.json | tr -d '\n')   # macOS
# Or single-line JSON: printf 'GOOGLE_CREDENTIALS_JSON=%s\n' "'$(jq -c . resources/client_secret.json)'" >> .env
# Test: python scripts/test_google_creds.py
